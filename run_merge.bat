@echo off
:: =============================================
:: Скрипт для запуска merge_fb2_library.py
:: Убедитесь, что Python установлен и доступен
:: =============================================

:: Включаем поддержку UTF-8 (для корректного отображения русских букв)
chcp 65001

:: Проверяем, установлен ли Python
python --version >nul 2>&1
if %errorlevel% neq 0 (
    echo ❌ Python не найден! Установите Python и добавьте его в PATH.
    pause
    exit /b 1
)

:: Запускаем скрипт
echo 🚀 Запуск скрипта объединения FB2-библиотек...
python "merge_fb2_library.py"

:: Завершаем и ждём нажатия клавиши, чтобы окно не закрылось
echo.
echo ✅ Готово. Нажмите любую клавишу, чтобы закрыть окно...
pause >nul